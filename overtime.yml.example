# overtime.yml — Cron for AI agents
# Run "overtime init" to set up credentials, or set env vars directly.

jobs:
  - name: pr-review
    schedule: "every day at 9am"
    task: "Review open PRs in this repo and leave comments"
    notify: slack

  - name: dep-updates
    schedule: "every monday at 2am"
    task: "Update dependencies, run tests, open PR if passing"

  - name: bug-triage
    schedule: "every 4 hours"
    task: "Check Linear for bugs labeled 'needs-triage', add priority labels"
    notify: slack

  # MCP servers: inline config or path to a JSON file
  - name: docs-agent
    schedule: "every day at 6am"
    task: "Check for outdated docs and open a PR with updates"
    mcp:
      filesystem:
        command: npx
        args: ["-y", "@modelcontextprotocol/server-filesystem", "/workspace"]

  - name: db-report
    schedule: "every weekday at 8am"
    task: "Query the database and summarize yesterday's key metrics"
    mcp: /home/user/.config/mcp-servers.json
